<Window x:Class="GameApp.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameApp.GUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        SizeChanged="Window_SizeChanged"
        MinWidth="900" MinHeight="450">

    <Grid Background="#111213">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="9*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="DEATH STRANDING 2: ON THE BEACH" Grid.Column="1" FontSize="32" FontWeight="SemiBold" Foreground="White"/>

        <ListView Grid.Column="0" Grid.Row="1"/>

        <Grid x:Name="MainContent" Grid.Column="1" Grid.Row="1" MinWidth="700" MinHeight="370" MaxWidth="830" MaxHeight="434" VerticalAlignment="Top" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="11"/>
                <ColumnDefinition Width="272"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="320"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <Image Source="/Images/2k5rHFB7scp6VLqu8UZLa9.jpg" Stretch="Uniform" VerticalAlignment="Top"/>


            <Grid Grid.Row="0" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="11*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <Image Source="/Images/header.jpg" Stretch="Uniform" Grid.Column="0" VerticalAlignment="Top" Grid.ColumnSpan="2"/>
                <TextBlock Text="Sam – with companions by his side – sets out on a new journey to save humanity from extinction. Join them as they traverse a world beset by otherworldly enemies, obstacles and a haunting question: should we have connected?" Grid.Column="0" Grid.Row="1" Width="272" TextWrapping="Wrap" VerticalAlignment="Top" Grid.ColumnSpan="2" Foreground="#E2E3E4"/>
                <TextBlock Text="Release Date:" Grid.Row="2" Foreground="#7E8188"/>
                <TextBlock Text="19 Mar, 2026" Grid.Row="2" Grid.Column="1" Foreground="#7E8188"/>

                <TextBlock Text="Developer:" Grid.Row="3" Foreground="#7E8188"/>
                <TextBlock Text="KOJIMA PRODUCTIONS" Grid.Row="3" Grid.Column="1" Foreground="#7E8188"/>

                <TextBlock Text="Publisher:" Grid.Row="4" Foreground="#7E8188"/>
                <TextBlock Text="PlayStation Publishing LLC" Grid.Row="4" Grid.Column="1" Foreground="#7E8188"/>
            </Grid>

            <Border Grid.Column="0" Grid.Row="1" Background="#2B2C2F">
                    <TextBlock Text="Pre-Purchase DEATH STRANDING 2: ON THE BEACH" FontSize="16" FontWeight="SemiBold" Foreground="WhiteSmoke"/>
            </Border>

            <Grid Grid.Column="2" Grid.Row="1" Background="#2B2C2F" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="5.5*"/>
                </Grid.ColumnDefinitions>

                <Image Source="/Images/PEGI_18.svg.png" Stretch="Uniform" HorizontalAlignment="Left" Margin="4,4,0,4" VerticalAlignment="Center"/>
                <TextBlock Text="Violence" Foreground="#CECFD2" Grid.Column="1" Margin="5,0,0,0"/>
                <TextBlock Text="Bad Language" Foreground="#CECFD2" Grid.Column="1" Margin="5,15,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
